<odoo>
    <record id="your_form_view" model="ir.ui.view">
        <field name="name">my.custom.model.form</field>
        <field name="model">my.custom.model</field>
        <field name="arch" type="xml">
            <form string="My Custom Model">
                <field name="name"/>
            </form>
        </field>
    </record>

    <record id="your_tree_view" model="ir.ui.view">
        <field name="name">my.custom.model.tree</field>
        <field name="model">my.custom.model</field>
        <field name="arch" type="xml">
            <tree string="My Custom Model">
                <field name="name"/>
            </tree>
        </field>
    </record>
</odoo>
